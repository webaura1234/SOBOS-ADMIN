generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Restaurant & Locations ───────────────────────────────────────────────

model Restaurant {
  id          String     @id @default(cuid())
  name        String
  tagline     String?
  description String?
  logoUrl     String?
  cuisineTags String     @default("[]")
  fssai       String?
  gstin       String?
  email       String?
  phone       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  locations   Location[]
  categories  MenuCategory[]
  items       MenuItem[]
  roles       Role[]
  users       User[]
  featureToggles FeatureToggle[]
}

model Location {
  id        String   @id @default(cuid())
  restaurantId String
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name      String
  address   String
  city      String
  pin       String
  phone     String?
  email     String?
  taxSlab   Int      @default(5)
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tables    RestaurantTable[]
  sections  TableSection[]
  stock     Stock[]
  orders    Order[]
  sessions  TableSession[]
  reservations Reservation[]
  operatingHours OperatingHours[]
  userRoles UserLocationRole[]
  wastage   WastageLog[]
  purchaseOrders PurchaseOrder[]
  alerts    Alert[]
}

model OperatingHours {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  dayOfWeek  Int
  openTime   String
  closeTime  String
  isClosed   Boolean  @default(false)
}

model HolidayClosure {
  id         String   @id @default(cuid())
  locationId String
  date       DateTime
  name       String
  createdAt  DateTime @default(now())
}

model FeatureToggle {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  key          String
  enabled      Boolean    @default(false)
  group        String
  @@unique([restaurantId, key])
}

// ─── Auth & Permissions ───────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  email        String?
  phone        String
  status       String   @default("active")
  inviteStatus String   @default("accepted")
  payRate      Float    @default(0)
  payType      String   @default("hourly")
  lastActive   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  locationRoles UserLocationRole[]
  attendance   Attendance[]
  auditLogs    AuditLog[] @relation("AuditActor")
  @@unique([restaurantId, phone])
}

model ShiftSwap {
  id           String   @id @default(cuid())
  slotId       String
  requesterId  String
  requesterName String
  withName     String?
  reason       String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())
}

model Role {
  id           String   @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  isTemplate   Boolean  @default(false)
  permissions  RolePermission[]
  assignments  UserLocationRole[]
  @@unique([restaurantId, name])
}

model Permission {
  id          String   @id @default(cuid())
  resource    String
  action      String
  label       String
  description String?
  group       String
  roles       RolePermission[]
  @@unique([resource, action])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@id([roleId, permissionId])
}

model UserLocationRole {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)
  roleId     String
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  @@unique([userId, locationId, roleId])
}

// ─── Menu & Recipe ────────────────────────────────────────────────────────

model MenuCategory {
  id           String   @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  parentId     String?
  parent       MenuCategory? @relation("CategoryTree", fields: [parentId], references: [id])
  children     MenuCategory[] @relation("CategoryTree")
  name         String
  displayOrder Int      @default(0)
  dietaryTag   String?
  icon         String?
  itemCount    Int      @default(0)
  hiddenLocations String @default("[]")
  items        MenuItem[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MenuItem {
  id             String   @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categoryId     String?
  category       MenuCategory? @relation(fields: [categoryId], references: [id])
  name           String
  description    String?
  basePrice      Float
  locationPrice  Float?
  dietaryFlags   String   @default("[]")
  allergenTags   String   @default("[]")
  prepTime       Int?
  taxCategory    String   @default("GST_5")
  availability   String   @default("available")
  autoOutOfStock Boolean  @default(false)
  recipeCost     Float    @default(0)
  grossMargin    Float    @default(0)
  marginAlertThreshold Float?
  unitsSold      Int      @default(0)
  photos         String   @default("[]")
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  variants       MenuItemVariant[]
  modifierGroups ModifierGroup[]
  substitutions  SubstitutionRule[]
  recipe         Recipe?
  orderItems     OrderItem[]
}

model MenuItemVariant {
  id        String   @id @default(cuid())
  itemId    String
  item      MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  label     String
  price     Float
  recipeNote String?
}

model ModifierGroup {
  id        String   @id @default(cuid())
  itemId    String
  item      MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  name      String
  required  Boolean  @default(false)
  minSelect Int      @default(0)
  maxSelect Int      @default(1)
  options   ModifierOption[]
}

model ModifierOption {
  id         String   @id @default(cuid())
  groupId    String
  group      ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  label      String
  priceDelta Float    @default(0)
}

model SubstitutionRule {
  id                     String   @id @default(cuid())
  itemId                 String
  item                   MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  primaryIngredientId    String
  primaryName            String
  substituteIngredientId String
  substituteName         String
  ratio                  Float    @default(1)
  requiresApproval       Boolean  @default(false)
}

model SeasonalSchedule {
  id           String   @id @default(cuid())
  restaurantId String
  itemId       String?
  categoryId   String?
  name         String
  startDate    DateTime
  endDate      DateTime
  recurring    Boolean  @default(false)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model Recipe {
  id       String   @id @default(cuid())
  itemId   String   @unique
  item     MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  version  Int      @default(1)
  ingredients RecipeIngredient[]
  snapshots   RecipeVersionSnapshot[]
}

model RecipeVersionSnapshot {
  id              String   @id @default(cuid())
  recipeId        String
  recipe          Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  version         Int
  ingredientsJson String
  recipeCost      Float    @default(0)
  createdAt       DateTime @default(now())
}

model RecipeIngredient {
  id           String   @id @default(cuid())
  recipeId     String
  recipe       Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Float
  unit         String
}

// ─── Inventory ────────────────────────────────────────────────────────────

model Ingredient {
  id          String   @id @default(cuid())
  name        String   @unique
  unit        String
  category    String?
  threshold   Float    @default(5)
  alertChannels String @default("[\"in_app\"]")
  lastUnitPrice Float  @default(0)
  stock       Stock[]
  batches     Batch[]
  recipeUses  RecipeIngredient[]
  wastage     WastageLog[]
  poLines     PurchaseOrderLine[]
  priceHistory IngredientPriceHistory[]
}

model IngredientPriceHistory {
  id           String   @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  unitPrice    Float
  supplierName String?
  recordedAt   DateTime @default(now())
}

model StockTransfer {
  id             String   @id @default(cuid())
  fromLocationId String
  fromName       String
  toLocationId   String
  toName         String
  ingredientId   String
  ingredientName String
  quantity       Float
  reason         String?
  status         String   @default("requested")
  createdAt      DateTime @default(now())
}

model Stock {
  id           String   @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  locationId   String
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  quantity     Float    @default(0)
  lastRestocked DateTime?
  @@unique([ingredientId, locationId])
}

model Batch {
  id           String   @id @default(cuid())
  number       String   @unique
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id])
  mfgDate      DateTime?
  expiryDate   DateTime?
  quantity     Float
  status       String   @default("active")
  createdAt    DateTime @default(now())
}

model WastageLog {
  id           String   @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  locationId   String
  location     Location @relation(fields: [locationId], references: [id])
  quantity     Float
  reason       String
  staffName    String?
  estCost      Float    @default(0)
  createdAt    DateTime @default(now())
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  contact     String?
  phone       String?
  email       String?
  address     String?
  categories  String   @default("[]")
  paymentTerms String?
  fssaiLicense String?
  rating      Float?
  leadTime    Int?
  isActive    Boolean  @default(true)
  batches     Batch[]
  purchaseOrders PurchaseOrder[]
  createdAt   DateTime @default(now())
}

model PurchaseOrder {
  id         String   @id @default(cuid())
  number     String   @unique
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  status     String   @default("draft")
  total      Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lines      PurchaseOrderLine[]
}

model PurchaseOrderLine {
  id              String   @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  ingredientId    String
  ingredient      Ingredient @relation(fields: [ingredientId], references: [id])
  qtyOrdered      Float
  qtyReceived     Float    @default(0)
  unitPrice       Float
}

// ─── Tables & Floor ───────────────────────────────────────────────────────

model TableSection {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name       String
  tables     RestaurantTable[]
}

model RestaurantTable {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  sectionId  String?
  section    TableSection? @relation(fields: [sectionId], references: [id])
  label      String
  minCapacity Int     @default(1)
  maxCapacity Int     @default(4)
  shape      String   @default("square")
  posX       Float    @default(0)
  posY       Float    @default(0)
  status     String   @default("available")
  qrCode     String?
  isDeleted  Boolean  @default(false)
  sessions   TableSession[]
  reservations Reservation[]
}

model TableSession {
  id         String   @id @default(cuid())
  tableId    String
  table      RestaurantTable @relation(fields: [tableId], references: [id])
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  guestCount Int      @default(1)
  serverName String?
  guestName  String?
  guestPhone String?
  specialRequests String?
  status     String   @default("open")
  orderTotal Float    @default(0)
  startedAt  DateTime @default(now())
  endedAt    DateTime?
}

// ─── Orders & Payments ────────────────────────────────────────────────────

model Order {
  id         String   @id @default(cuid())
  number     String   @unique
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  source     String   @default("dine_in")
  status     String   @default("pending")
  subtotal   Float    @default(0)
  tax        Float    @default(0)
  total      Float    @default(0)
  tableLabel String?
  customerName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  items      OrderItem[]
  refunds    Refund[]
}

model OrderItem {
  id       String   @id @default(cuid())
  orderId  String
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemId   String?
  item     MenuItem? @relation(fields: [itemId], references: [id])
  name     String
  quantity Int      @default(1)
  price    Float
  status   String   @default("active")
}

model Refund {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  amount    Float
  reason    String
  status    String   @default("processing")
  issuedBy  String?
  createdAt DateTime @default(now())
}

model KdsStation {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  itemIds      String   @default("[]")
  createdAt    DateTime @default(now())
}

model PaymentConfig {
  id              String  @id @default(cuid())
  restaurantId    String  @unique
  razorpayKey     String?
  razorpaySecret  String?
  webhookUrl      String?
  testMode        Boolean @default(true)
  cashEnabled     Boolean @default(true)
  cardEnabled     Boolean @default(false)
  upiEnabled      Boolean @default(false)
  walletEnabled   Boolean @default(false)
  splitEnabled    Boolean @default(false)
  splitMax        Int     @default(0)
  tipsEnabled     Boolean @default(true)
  tipPooling      String  @default("per_server")
  tipType         String  @default("percentage")
  swiggyRate      Float   @default(18)
  zomatoRate      Float   @default(20)
  ondcRate        Float   @default(10)
}

model Settlement {
  id           String   @id @default(cuid())
  restaurantId String
  source       String
  period       String
  gross        Float    @default(0)
  commission   Float    @default(0)
  net          Float    @default(0)
  status       String   @default("pending")
  markedAt     DateTime?
  createdAt    DateTime @default(now())
  @@unique([restaurantId, source, period])
}

model CashReconciliation {
  id          String   @id @default(cuid())
  locationId  String
  date        DateTime @default(now())
  expected    Float
  actual      Float
  variance    Float
  note        String?
  createdAt   DateTime @default(now())
}

// ─── Staff & Labor ────────────────────────────────────────────────────────

model Attendance {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clockIn    DateTime
  clockOut   DateTime?
  location   String?
  isLate     Boolean  @default(false)
  autoClosed Boolean  @default(false)
}

model ScheduleSlot {
  id         String   @id @default(cuid())
  userId     String
  locationId String
  dayOfWeek  Int
  startTime  String
  endTime    String
  status     String   @default("published")
}

// ─── Customers & Loyalty ──────────────────────────────────────────────────

model Customer {
  id          String   @id @default(cuid())
  name        String
  phone       String   @unique
  email       String?
  tier        String   @default("silver")
  totalSpend  Float    @default(0)
  visitCount  Int      @default(0)
  lastVisit   DateTime?
  tags        String   @default("[]")
  points      Int      @default(0)
  favoriteDishes String @default("[]")
  dietaryNotes String?
  serviceNotes String?
  birthday    DateTime?
  anniversary DateTime?
  optedOut    Boolean  @default(false)
  createdAt   DateTime @default(now())
  reservations Reservation[]
  campaigns   CampaignRecipient[]
}

model LoyaltyProgram {
  id              String  @id @default(cuid())
  restaurantId    String  @unique
  earnRate        Float   @default(1)
  redeemRate      Float   @default(0.25)
  minRedeem       Int     @default(100)
  expiryMonths    Int     @default(12)
  maxDiscountPct  Int     @default(20)
  goldThreshold   Float   @default(10000)
  platinumThreshold Float @default(50000)
  goldMultiplier  Float   @default(1.5)
  platinumMultiplier Float @default(2)
  awardOnAggregator Boolean @default(false)
  enabled         Boolean @default(true)
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  segment     String
  message     String
  channel     String   @default("whatsapp")
  offerCode   String?
  status      String   @default("draft")
  sentCount   Int      @default(0)
  readCount   Int      @default(0)
  redeemCount Int      @default(0)
  scheduledAt DateTime?
  createdAt   DateTime @default(now())
  recipients  CampaignRecipient[]
}

model AutoOffer {
  id           String   @id @default(cuid())
  restaurantId String
  type         String   // birthday | anniversary
  enabled      Boolean  @default(false)
  daysBefore   Int      @default(3)
  offerType    String   @default("percent") // percent | free_item | bonus_points
  value        Float    @default(10)
  validityDays Int      @default(7)
  channel      String   @default("whatsapp")
  skipLapsed   Boolean  @default(true)
  @@unique([restaurantId, type])
}

model ReferralConfig {
  id            String  @id @default(cuid())
  restaurantId  String  @unique
  enabled       Boolean @default(false)
  referrerReward Float  @default(100)
  refereeReward Float   @default(50)
  maxPerMonth   Int     @default(5)
  trigger       String  @default("referee_first_order")
}

model Waitlist {
  id           String   @id @default(cuid())
  locationId   String
  guestName    String
  phone        String?
  partySize    Int
  estWaitMin   Int      @default(15)
  notifyChannel String  @default("sms")
  status       String   @default("waiting") // waiting | notified | seated | no_show
  createdAt    DateTime @default(now())
}

model CampaignRecipient {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  status     String   @default("pending")
}

model Reservation {
  id           String   @id @default(cuid())
  locationId   String
  location     Location @relation(fields: [locationId], references: [id])
  tableId      String?
  table        RestaurantTable? @relation(fields: [tableId], references: [id])
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id])
  guestName    String
  guestPhone   String?
  partySize    Int
  dateTime     DateTime
  duration     Int      @default(90)
  status       String   @default("confirmed")
  noShowScore  Int      @default(20)
  specialRequests String?
  preOrder     String?
  reminderConfirmed Boolean @default(false)
  createdAt    DateTime @default(now())
}

// ─── Integrations ─────────────────────────────────────────────────────────

model Integration {
  id           String   @id @default(cuid())
  restaurantId String
  provider     String
  enabled      Boolean  @default(false)
  config       String   @default("{}")
  lastSync     DateTime?
  syncStatus   String   @default("idle")
  createdAt    DateTime @default(now())
  @@unique([restaurantId, provider])
}

model SyncLog {
  id            String   @id @default(cuid())
  integrationId String
  provider      String
  status        String   @default("success")
  message       String
  createdAt     DateTime @default(now())
}

model AdminConfig {
  id           String   @id @default(cuid())
  restaurantId String
  scope        String   @default("global")
  key          String
  value        String   @default("{}")
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
  @@unique([restaurantId, scope, key])
}

model SavedView {
  id           String   @id @default(cuid())
  restaurantId String
  module       String
  name         String
  filters      String   @default("{}")
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@unique([restaurantId, module, name])
}

// ─── Audit & Alerts ───────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String?
  actor        User?    @relation("AuditActor", fields: [actorId], references: [id])
  actorName    String
  action       String
  resourceType String
  resourceId   String?
  beforeJson   String?
  afterJson    String?
  ip           String?
  createdAt    DateTime @default(now())
}

model Alert {
  id         String   @id @default(cuid())
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])
  type       String
  title      String
  message    String
  severity   String   @default("info")
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Review {
  id           String   @id @default(cuid())
  restaurantId String
  author       String
  rating       Int
  text         String?
  source       String   @default("google")
  reviewedAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  category  String   @default("system")
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
